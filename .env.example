# Configuración de Base de Datos PostgreSQL
# Copia este archivo a .env y ajusta los valores

# URL de conexión JDBC a PostgreSQL
# Formato: jdbc:postgresql://hostname:port/database_name
DATABASE_URL=jdbc:postgresql://localhost:5432/farmacia

# Usuario de PostgreSQL
DATABASE_USER=postgres

# Contraseña de PostgreSQL
DATABASE_PASSWORD=postgres

# Opciones JVM (opcional)
# Útil para limitar memoria en ambientes con recursos limitados
JAVA_OPTS=-Xmx512m -Xms256m

# ============================================
# EJEMPLOS PARA PROVEEDORES ESPECÍFICOS
# ============================================

# --- Neon (https://neon.tech) ---
# DATABASE_URL=jdbc:postgresql://ep-xxx-xxx.us-east-2.aws.neon.tech/farmacia?sslmode=require
# DATABASE_USER=tu_usuario_neon
# DATABASE_PASSWORD=tu_password_neon

# --- Supabase (https://supabase.com) ---
# DATABASE_URL=jdbc:postgresql://db.xxx.supabase.co:5432/postgres?sslmode=require
# DATABASE_USER=postgres
# DATABASE_PASSWORD=tu_password_supabase

# --- ElephantSQL (https://www.elephantsql.com) ---
# DATABASE_URL=jdbc:postgresql://xxx.db.elephantsql.com/xxx
# DATABASE_USER=xxx
# DATABASE_PASSWORD=tu_password_elephant

# --- Koyeb Managed PostgreSQL ---
# DATABASE_URL=jdbc:postgresql://xxx.koyeb.app:5432/koyebdb
# DATABASE_USER=koyeb-adm
# DATABASE_PASSWORD=tu_password_koyeb

# ============================================
# NOTAS
# ============================================
# - Para desarrollo local con Docker: usa los valores por defecto arriba
# - Para Koyeb/producción: configura estas variables en la UI de Koyeb, no uses archivo .env
# - Para SQLite (solo desarrollo): ejecuta con -Dspring-boot.run.profiles=dev
